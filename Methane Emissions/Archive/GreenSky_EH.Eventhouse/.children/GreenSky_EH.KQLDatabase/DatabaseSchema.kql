.create-merge table methane_emissions (event_id:string, date_key:real, event_date:datetime, detection_timestamp:datetime, facility_key:long, equipment_key:long, emission_kg_per_hour:real, emission_severity:string, duration_hours:long, total_methane_loss_mcf:real, financial_impact_usd:real, compliance_risk_score:long, scada_anomaly_detected:long, work_order_generated:string, detection_source:string, response_time_hours:string, distance_meters:real) 
.create-or-alter table methane_emissions ingestion csv mapping 'methane_emissions_mapping'
