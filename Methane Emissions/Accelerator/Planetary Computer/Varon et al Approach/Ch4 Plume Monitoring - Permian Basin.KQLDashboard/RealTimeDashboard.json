  "queries": [
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "4255c18d-0a56-42d7-82ff-1304cd757ca5"
      },
      "text": "ch4_plume_catalog\r\n| summarize TotalPlumes = count()",
      "id": "22a3b2bd-1ca8-4e2e-82f7-6950c54c9e84",
      "usedVariables": []
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "4255c18d-0a56-42d7-82ff-1304cd757ca5"
      },
      "text": "ch4_plume_catalog\r\n| summarize\r\n    HighConfidence = countif(emission_rate_confidence == \"high\"),\r\n    TotalPlumes    = count()\r\n| extend PctHigh = round(100.0 * HighConfidence / TotalPlumes, 1)\r\n| project HighConfidence, PctHigh",
      "id": "e3fcae82-9d63-486c-b8b6-94d6f8aec587",
      "usedVariables": []
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "4255c18d-0a56-42d7-82ff-1304cd757ca5"
      },
      "text": "ch4_plume_ready\r\n| where acquisition_date between (_startTime .. _endTime)\r\n| summarize\r\n    TotalReadings   = count(),\r\n    QualityReadings = countif(qa_value >= 0.5)\r\n| extend QualityPct = round(100.0 * QualityReadings / TotalReadings, 1)\r\n| project QualityPct, QualityReadings, TotalReadings",
      "id": "b7fed876-2131-4ed2-b5bb-177556e84163",
      "usedVariables": [
        "_endTime",
        "_startTime"
      ]
    },
    {
      "dataSource": {
        "kind": "inline",
